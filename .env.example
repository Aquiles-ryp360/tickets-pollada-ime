# Persistencia compartida en Supabase para Vercel.
# Si estas variables no existen, la app funciona en modo local del navegador.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: protege la app con un PIN simple.
APP_ACCESS_PIN=

# Opcional: autollenado por DNI mediante el proxy seguro en Ubuntu.
DNI_PROXY_URL=https://server-juliaca.tailb6baea.ts.net
DNI_PROXY_SECRET=REEMPLAZAR_CON_SECRETO_DEL_SERVIDOR
DNI_LOOKUP_ENABLED=true
DNI_PROXY_TIMEOUT_MS=8000

# Opcional: autollenado por codigo UNA. Por defecto usa carrera 36: IME.
UNAP_LOOKUP_ENABLED=true
UNAP_LOOKUP_BASE_URL=https://tramites.unap.edu.pe
UNAP_DEFAULT_CAREER_CODE=36
UNAP_DEFAULT_CAREER_NAME=INGENIERÍA MECÁNICA ELÉCTRICA
